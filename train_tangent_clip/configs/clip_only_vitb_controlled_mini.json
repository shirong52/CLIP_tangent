{
  "model": {
    "model_path": "/root/autodl-tmp/model/clip_vit_b",
    "trainable_strategy": "last_n",
    "unfreeze_last_n": 2
  },
  "data": {
    "dataset_root": "/root/autodl-tmp/dataset/composition/controlled_pairs",
    "train_jsonl": "/root/autodl-tmp/dataset/composition/controlled_pairs/train.jsonl",
    "val_jsonl": "/root/autodl-tmp/dataset/composition/controlled_pairs/test.jsonl",
    "max_text_length": 64,
    "factors": ["relation", "color", "shape", "anchor_color"]
  },
  "loss": {
    "mode": "clip_only",
    "lambda_tan": 0.0,
    "lambda_consistency": 0.0,
    "lambda_reg": 0.0
  },
  "optim": {
    "lr": 1e-5,
    "weight_decay": 0.01,
    "betas": [0.9, 0.98],
    "eps": 1e-6,
    "warmup_ratio": 0.1,
    "max_grad_norm": 1.0
  },
  "train": {
    "seed": 42,
    "batch_size": 32,
    "num_workers": 4,
    "epochs": 25,
    "amp": true,
    "log_every": 20,
    "output_dir": "/root/autodl-tmp/output/clip_only_vitb_controlled"
  },
  "eval": {
    "ks": [1, 5, 10],
    "primary_metrics": ["i2t_r@1", "t2i_r@1", "i2t_r@5", "t2i_r@5"]
  }
}
